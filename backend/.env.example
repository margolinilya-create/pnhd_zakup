# Database: Supabase (managed Postgres) via the Session Pooler — see docs/LOCAL_DATABASE.md.
# Get <PASSWORD> from the Supabase dashboard (Project Settings -> Database -> Reset database password).
# Use the Session Pooler host (IPv4); the direct db.<ref>.supabase.co host is IPv6-only.
DATABASE_URL="postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require&schema=public"

# Tests run in a separate schema (app_test) in the SAME Supabase database (no Docker).
TEST_DATABASE_URL="postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require&schema=app_test"
# Supabase has no local Docker DB and its database is always named "postgres",
# so skip Docker and bypass the name-based *_test guard (isolation is the schema).
TEST_SKIP_DOCKER="1"
TEST_ALLOW_NON_TEST_DATABASE="1"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# Optional DigitalOcean Spaces storage. Leave blank until the product needs
# uploads, media, or other persistent files.
SPACES_REGION=""
SPACES_BUCKET=""
SPACES_ENDPOINT=""
SPACES_CDN_BASE_URL=""
SPACES_ACCESS_KEY_ID=""
SPACES_SECRET_ACCESS_KEY=""
SPACES_UPLOAD_MAX_BYTES="10485760"
SPACES_UPLOAD_URL_TTL_SECONDS="900"
SPACES_DOWNLOAD_URL_TTL_SECONDS="300"
SPACES_PUBLIC_CACHE_CONTROL="public, max-age=31536000, immutable"
