{
  "name": "@web-app-demo/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run prisma:generate && bun --watch src/index.ts",
    "start": "bun run prisma:generate && bun src/index.ts",
    "start:raw": "bun src/index.ts",
    "build": "bun run prisma:generate && tsc --noEmit",
    "typecheck": "bun run prisma:generate && tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test src/env.test.ts src/contracts.test.ts src/auth/access-tokens.test.ts src/auth/passwords.test.ts src/auth/refresh-tokens.test.ts",
    "test:integration": "bun scripts/test-integration.mjs",
    "smoke:docker": "bun scripts/docker-smoke.mjs",
    "prisma": "prisma",
    "prisma:generate": "bun scripts/prisma-generate.mjs",
    "prisma:generate:raw": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.1.5",
    "@hono/zod-validator": "^0.7.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@web-app-demo/contracts": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.12.18",
    "jose": "^6.1.3",
    "zod": "^4.1.13",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/pg": "^8.16.0",
    "prisma": "^7.8.0",
    "typescript": "~6.0.2"
  }
}
